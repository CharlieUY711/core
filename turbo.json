{
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "apps/core-landing/.next/**",
        "apps/core-market/dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    }
  },
  "globalEnv": [
    "CORE_APP_ID",
    "CORE_ACCESS_SECRET",
    "NEXT_PUBLIC_CORE_APP_ID",
    "NEXT_PUBLIC_WORKSPACE_URL"
  ]
}